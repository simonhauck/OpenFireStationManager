          "username": {
            "type": "string"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["USER", "ADMIN", "KLEIDERWART"]
            }
          },
          "enabled": {
            "type": "boolean"
