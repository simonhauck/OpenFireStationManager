{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", ":dependencyDashboard", ":automergeAll"],
  "automergeType": "branch",
  "labels": ["dependencies"],
  "npm": {
    "enabled": true
  },
  "minimumReleaseAge": "14 days",
  "packageRules": [
    {
      "groupName": "Tanstack packages",
      "matchPackageNames": ["@tanstack/**"]
    }
  ]
}
